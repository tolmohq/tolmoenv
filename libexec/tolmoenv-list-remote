#!/usr/bin/env bash
set -euo pipefail

TOLMOENV_ROOT="${TOLMOENV_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
source "$TOLMOENV_ROOT/lib/helpers.sh"

filter="all"
for arg in "$@"; do
  case "$arg" in
    --stable)  filter="stable" ;;
    --nightly) filter="nightly" ;;
    --all)     filter="all" ;;
    --help|-h)
      echo "Usage: tolmoenv list-remote [--stable|--nightly|--all]"
      exit 0
      ;;
    *)
      log_error "Unknown option: $arg" "usage: tolmoenv list-remote [--stable|--nightly|--all]"
      ;;
  esac
done

log_debug "Fetching releases from GitHub (filter: $filter)..."

# Fetch all releases (including pre-releases) from GitHub API
releases="$(curl -fsSL \
  -H "Accept: application/vnd.github+json" \
  -H "User-Agent: tolmoenv" \
  "https://api.github.com/repos/${TOLMOENV_REPO}/releases?per_page=100")"

if [ -z "$releases" ]; then
  log_error "Could not fetch releases from GitHub"
fi

RELEASES_JSON="$releases" python3 - "$filter" <<'PY'
import json
import os
import sys

filter_name = sys.argv[1]
try:
    releases = json.loads(os.environ["RELEASES_JSON"])
except json.JSONDecodeError:
    sys.exit("Could not parse releases from GitHub")

versions = []
for release in releases:
    tag_name = release.get("tag_name", "")
    created_at = release.get("created_at", "")
    if not tag_name.startswith("v"):
        continue

    version = tag_name[1:]
    is_nightly = "nightly" in version

    if filter_name == "stable" and is_nightly:
        continue
    if filter_name == "nightly" and not is_nightly:
        continue

    versions.append((created_at, version))

for _, version in sorted(versions, key=lambda item: (item[0], item[1])):
    print(version)
PY
