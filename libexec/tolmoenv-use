#!/usr/bin/env bash
set -euo pipefail

TOLMOENV_ROOT="${TOLMOENV_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
source "$TOLMOENV_ROOT/lib/helpers.sh"

[ "$#" -gt 1 ] && log_error "Expected 1 argument" "usage: tolmoenv use [<version>]"

version_requested="${1:-""}"
[ -n "$version_requested" ] || log_error "Version is not specified" "usage: tolmoenv use <version>"

# Strip leading v
version_requested="${version_requested#v}"

# Resolve "latest" and "latest:nightly"
if [ "$version_requested" = "latest" ]; then
  version_requested="$(run_tolmoenv_subcommand list-remote --stable | tail -1)"
  [ -n "$version_requested" ] || log_error "Could not determine latest stable version"
elif [ "$version_requested" = "latest:nightly" ]; then
  version_requested="$(run_tolmoenv_subcommand list-remote --nightly | tail -1)"
  [ -n "$version_requested" ] || log_error "Could not determine latest nightly version"
fi

# Check if installed, auto-install if not
target_dir="$TOLMOENV_ROOT/versions/$version_requested"
if [ ! -x "$target_dir/tolmo" ]; then
  log_info "tolmo $version_requested is not installed, installing..."
  run_tolmoenv_subcommand install "$version_requested" || log_error "Installation of $version_requested failed"
fi

# Write version file
echo "$version_requested" > "$TOLMOENV_ROOT/version"
log_info "Switched to tolmo $version_requested"

"$target_dir/tolmo" --version
